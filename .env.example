# =============================================================================
# Variables d'environnement — TEMPLATE (copier vers .env et adapter)
# NE JAMAIS commiter le fichier .env ! Il contient des mots de passe.
# =============================================================================

# PostgreSQL
POSTGRES_USER=velib
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=velib_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# APIs
VELIB_API_BASE_URL=https://opendata.paris.fr/api/explore/v2.1/catalog/datasets/velib-disponibilite-en-temps-reel/records
VELIB_API_PAGE_SIZE=100
METEO_API_URL=https://api.open-meteo.com/v1/forecast?latitude=48.8534&longitude=2.3488&current=temperature_2m,relative_humidity_2m,apparent_temperature,is_day,precipitation,rain,showers,snowfall,cloud_cover,wind_speed_10m&timezone=Europe%2FParis&forecast_days=1

# Airflow
# Générer AIRFLOW_FERNET_KEY  : python3 -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# Générer AIRFLOW_SECRET_KEY  : python3 -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_FERNET_KEY=changeme_generate_with_command_above
AIRFLOW_SECRET_KEY=changeme_generate_with_command_above
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme_strong_password

# Airflow — alertes mail (SMTP Gmail)
# AIRFLOW_SMTP_PASSWORD : App Password Google (16 caractères, pas ton mot de passe Gmail)
# Générer sur : myaccount.google.com > Sécurité > Mots de passe des applications
AIRFLOW_SMTP_USER=ton.adresse@gmail.com
AIRFLOW_SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx
AIRFLOW_ALERT_EMAIL=ton.adresse@gmail.com
